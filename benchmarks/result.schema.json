{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itdo.jp/schemas/private-match/research/technology-bakeoff-result-0.1.json",
  "title": "Private Match technology bake-off result v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "track_id",
    "result_origin",
    "status",
    "executed_at",
    "source_revision",
    "environment",
    "commands",
    "evidence",
    "measurements",
    "observations",
    "limitations"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "experiment_id": {"pattern": "^EXP-00[1-8]$"},
    "track_id": {"pattern": "^TRACK-[A-Z0-9-]+$"},
    "result_origin": {"const": "local"},
    "status": {
      "enum": ["pass", "fail", "skip", "unsupported", "timeout", "tool-error"]
    },
    "executed_at": {"type": "string", "format": "date-time"},
    "source_revision": {
      "type": "string",
      "minLength": 7,
      "description": "Must exactly equal the selected track source_revision pin in experiment-matrix.yaml; the validator enforces the track-specific value."
    },
    "environment": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": ["string", "number", "boolean"]}
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["argv", "exit_code"],
        "properties": {
          "argv": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "exit_code": {"type": ["integer", "null"]}
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stdout_sha256", "stderr_sha256", "input_artifacts", "output_artifacts"],
      "properties": {
        "stdout_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_sha256": {"$ref": "#/$defs/sha256"},
        "input_artifacts": {"$ref": "#/$defs/digests", "minProperties": 1},
        "output_artifacts": {"$ref": "#/$defs/digests"}
      }
    },
    "measurements": {"type": "object"},
    "observations": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "digests": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "pass"}}},
      "then": {
        "properties": {
          "evidence": {
            "properties": {"output_artifacts": {"minProperties": 1}}
          }
        }
      }
    }
  ]
}
